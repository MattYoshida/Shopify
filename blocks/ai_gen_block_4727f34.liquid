{% doc %}
  @prompt
    Customizable button that scrolls down to the Apps Section Loox review widget, make the star smaller, I want to also be able to edit the backround collor, Great but it should scroll down to the product reviews widget not to the top o the page, Have it scroll down to my colleciton button not the reviews
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scroll-button-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.section_background }};
  }

  .ai-scroll-button-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.alignment }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-scroll-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    {% if block.settings.button_style == 'square' %}
      border-radius: 0;
    {% elsif block.settings.button_style == 'slightly' %}
      border-radius: 4px;
    {% elsif block.settings.button_style == 'rounded' %}
      border-radius: 8px;
    {% elsif block.settings.button_style == 'pill' %}
      border-radius: 50px;
    {% endif %}
    {% if block.settings.text_transform == 'uppercase' %}
      text-transform: uppercase;
    {% elsif block.settings.text_transform == 'lowercase' %}
      text-transform: lowercase;
    {% elsif block.settings.text_transform == 'capitalize' %}
      text-transform: capitalize;
    {% endif %}
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  .ai-scroll-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.border_hover_color }};
    transform: translateY(-2px);
  }

  .ai-scroll-button-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-scroll-button-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-scroll-button-container-{{ ai_gen_id }} {
      justify-content: {{ block.settings.mobile_alignment }};
    }

    .ai-scroll-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding_vertical | times: 0.85 }}px {{ block.settings.button_padding_horizontal | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-scroll-button-wrapper-{{ ai_gen_id }}">
  <scroll-to-section-{{ ai_gen_id }}
    class="ai-scroll-button-container-{{ ai_gen_id }}"
    {{ block.shopify_attributes }}
  >
    <button
      class="ai-scroll-button-{{ ai_gen_id }}"
      type="button"
      aria-label="{{ block.settings.button_text }}"
    >
      {% if block.settings.show_icon and block.settings.icon_position == 'left' %}
        <span class="ai-scroll-button-icon-{{ ai_gen_id }}">
          {% if block.settings.icon_style == 'arrow' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <polyline points="19 12 12 19 5 12"></polyline>
            </svg>
          {% elsif block.settings.icon_style == 'chevron' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          {% elsif block.settings.icon_style == 'star' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          {% endif %}
        </span>
      {% endif %}

      <span>{{ block.settings.button_text }}</span>

      {% if block.settings.show_icon and block.settings.icon_position == 'right' %}
        <span class="ai-scroll-button-icon-{{ ai_gen_id }}">
          {% if block.settings.icon_style == 'arrow' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <polyline points="19 12 12 19 5 12"></polyline>
            </svg>
          {% elsif block.settings.icon_style == 'chevron' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          {% elsif block.settings.icon_style == 'star' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          {% endif %}
        </span>
      {% endif %}
    </button>
  </scroll-to-section-{{ ai_gen_id }}>
</div>

<script>
  (function() {
    class ScrollToSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.button = this.querySelector('.ai-scroll-button-{{ ai_gen_id }}');
        this.targetSelector = '{{ block.settings.target_selector }}';
        this.scrollOffset = {{ block.settings.scroll_offset }};
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.button.addEventListener('click', () => {
          this.scrollToTarget();
        });
      }

      scrollToTarget() {
        let targetElement = null;

        if (this.targetSelector) {
          targetElement = document.querySelector(this.targetSelector);
        }

        if (!targetElement) {
          const selectors = [
            '[id*="collection"]',
            '[class*="collection"]',
            '[data-collection]',
            '.collection-list',
            '#collection-list',
            '.featured-collection',
            '#featured-collection'
          ];

          for (const selector of selectors) {
            targetElement = document.querySelector(selector);
            if (targetElement) {
              break;
            }
          }
        }

        if (targetElement) {
          const elementPosition = targetElement.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.pageYOffset - this.scrollOffset;

          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
        } else {
          console.warn('Target section not found on the page');
        }
      }
    }

    customElements.define('scroll-to-section-{{ ai_gen_id }}', ScrollToSection{{ ai_gen_id }});
  })();
</script>

