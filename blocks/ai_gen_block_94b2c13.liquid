{% doc %}
  @prompt
    An image with text block with the ability to choose what side the image is on. also the abilty to change the aspect ratio of the image. I also want text customizability, I want to be able to choose the position of the image if i want it flush left or lush right or in the center like it is now, I also want to be able to adjust the location of the text , I also want to be able to edit wether I want the text as well as the heading to be shown on mobile or desktop
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout }};
    gap: {{ block.settings.gap }}px;
    align-items: center;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-image-text-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.container_width }}px;
    {% if block.settings.container_alignment == 'left' %}
      margin-left: 0;
      margin-right: auto;
    {% elsif block.settings.container_alignment == 'right' %}
      margin-left: auto;
      margin-right: 0;
    {% else %}
      margin: 0 auto;
    {% endif %}
  }

  .ai-image-text-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout }};
    gap: {{ block.settings.gap }}px;
    align-items: center;
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    position: relative;
    overflow: hidden;
  }

  .ai-image-text-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
  }

  .ai-image-text-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-text-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-image-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    flex: 0 0 calc(100% - {{ block.settings.image_width }}%);
    padding: {{ block.settings.content_padding }}px;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.content_vertical_alignment }};
  }

  .ai-image-text-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
    line-height: 1.2;
  }

  .ai-image-text-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    color: {{ block.settings.text_color }};
    line-height: {{ block.settings.text_line_height }};
    text-align: {{ block.settings.text_alignment }};
    margin: 0;
  }

  .ai-image-text-button-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.button_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-text-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: {{ block.settings.button_text_weight }};
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
  }

  .ai-image-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
  }

  @media screen and (min-width: 750px) {
    {% unless block.settings.show_heading_desktop %}
      .ai-image-text-heading-{{ ai_gen_id }} {
        display: none;
      }
    {% endunless %}

    {% unless block.settings.show_text_desktop %}
      .ai-image-text-text-{{ ai_gen_id }} {
        display: none;
      }
    {% endunless %}
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-wrapper-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
    }

    .ai-image-text-image-{{ ai_gen_id }},
    .ai-image-text-content-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-image-text-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-image-text-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }

    .ai-image-text-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.6 }}px {{ block.settings.padding_horizontal | times: 0.6 }}px {{ block.settings.padding_bottom | times: 0.6 }}px;
    }

    {% unless block.settings.show_heading_mobile %}
      .ai-image-text-heading-{{ ai_gen_id }} {
        display: none;
      }
    {% endunless %}

    {% unless block.settings.show_text_mobile %}
      .ai-image-text-text-{{ ai_gen_id }} {
        display: none;
      }
    {% endunless %}
  }
{% endstyle %}

<div class="ai-image-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-container-{{ ai_gen_id }}">
    <div class="ai-image-text-wrapper-{{ ai_gen_id }}">
      <div class="ai-image-text-image-{{ ai_gen_id }}">
        <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.image %}
            <img
              src="{{ block.settings.image | image_url: width: 2000 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {% else %}
            <div class="ai-image-text-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-image-text-empty-state-{{ ai_gen_id }}">
                Next, add an image
              </div>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-image-text-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-image-text-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="ai-image-text-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
        {% endif %}

        {% if block.settings.button_label != blank and block.settings.button_link != blank %}
          <div class="ai-image-text-button-wrapper-{{ ai_gen_id }}">
            <a href="{{ block.settings.button_link }}" class="ai-image-text-button-{{ ai_gen_id }}">
              {{ block.settings.button_label }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        {
          "value": "row",
          "label": "Left"
        },
        {
          "value": "row-reverse",
          "label": "Right"
        }
      ],
      "default": "row"
    },
    {
      "type": "select",
      "id": "container_alignment",
      "label": "Container alignment",
      "options": [
        {
          "value": "left",
          "label": "Flush left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Flush right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_vertical_alignment",
      "label": "Text vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "column",
          "label": "Image on top"
        },
        {
          "value": "column-reverse",
          "label": "Image on bottom"
        }
      ],
      "default": "column"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 600,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Container width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Gap between image and text",
      "default": 40
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 30,
      "max": 70,
      "step": 5,
      "unit": "%",
      "label": "Image width",
      "default": 50
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "1 / 1",
          "label": "Square (1:1)"
        },
        {
          "value": "4 / 3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "3 / 4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "16 / 9",
          "label": "Wide (16:9)"
        },
        {
          "value": "9 / 16",
          "label": "Tall (9:16)"
        },
        {
          "value": "21 / 9",
          "label": "Ultrawide (21:9)"
        }
      ],
      "default": "4 / 3"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Image with text"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "content_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Content padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_heading_desktop",
      "label": "Show heading on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_heading_mobile",
      "label": "Show heading on mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_text_desktop",
