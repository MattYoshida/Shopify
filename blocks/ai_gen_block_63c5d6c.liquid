{% doc %}
  @prompt
    Desktop Layout:
    
    Two images displayed side by side, centered on page
    Individual aspect ratio control per image
    
    Mobile Layout:
    
    Swipeable carousel showing ONE full image at a time
    No partial/half images visible (hide overflow)
    Pagination dots below images:
    
    Inactive: light gray circle
    Active: dark/opaque circle
    Dot position updates on swipe
    
    
    
    Styling Controls:
    
    Section background theme/color scheme selector
    Container background theme/color scheme selector, I should have control over the container width, On desktop iinstead of the slider fo r container wideth i t should be a direct value inputdesktop mobile images should adapt to the image size , give me the ability to add borders on all sides with values and give me the ability to make the images smaller, i want ability to adjust the gap inbetween the images
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-comparison-{{ ai_gen_id }} {
    background-color: rgb(var(--color-background));
  }

  .ai-image-comparison-container-{{ ai_gen_id }} {
    background-color: rgb(var(--color-background));
    padding: 40px 20px;
  }

  .ai-image-comparison-wrapper-{{ ai_gen_id }} {
    {% if block.settings.container_width != blank %}
      max-width: {{ block.settings.container_width }};
    {% else %}
      max-width: 1200px;
    {% endif %}
    margin: 0 auto;
  }

  .ai-image-comparison-desktop-{{ ai_gen_id }} {
    display: none;
    gap: {{ block.settings.image_gap }}px;
    justify-content: center;
  }

  .ai-image-comparison-image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 auto;
    max-width: 100%;
    border-top: {{ block.settings.border_top }}px solid {{ block.settings.border_color }};
    border-right: {{ block.settings.border_right }}px solid {{ block.settings.border_color }};
    border-bottom: {{ block.settings.border_bottom }}px solid {{ block.settings.border_color }};
    border-left: {{ block.settings.border_left }}px solid {{ block.settings.border_color }};
  }

  .ai-image-comparison-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .ai-image-comparison-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .ai-image-comparison-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-image-comparison-mobile-{{ ai_gen_id }} {
    display: block;
    position: relative;
    overflow: hidden;
  }

  .ai-image-comparison-carousel-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.3s ease;
    touch-action: pan-y;
  }

  .ai-image-comparison-slide-{{ ai_gen_id }} {
    flex: 0 0 100%;
    width: 100%;
  }

  .ai-image-comparison-slide-{{ ai_gen_id }} img,
  .ai-image-comparison-slide-{{ ai_gen_id }} .ai-image-comparison-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-image-comparison-slide-{{ ai_gen_id }} .ai-image-comparison-image-wrapper-{{ ai_gen_id }} {
    border-top: {{ block.settings.border_top }}px solid {{ block.settings.border_color }};
    border-right: {{ block.settings.border_right }}px solid {{ block.settings.border_color }};
    border-bottom: {{ block.settings.border_bottom }}px solid {{ block.settings.border_color }};
    border-left: {{ block.settings.border_left }}px solid {{ block.settings.border_color }};
  }

  .ai-image-comparison-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
  }

  .ai-image-comparison-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #d3d3d3;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-image-comparison-dot-{{ ai_gen_id }}.active {
    background-color: #333333;
  }

  @media screen and (min-width: 750px) {
    .ai-image-comparison-desktop-{{ ai_gen_id }} {
      display: flex;
    }

    .ai-image-comparison-mobile-{{ ai_gen_id }} {
      display: none;
    }

    .ai-image-comparison-image-wrapper-{{ ai_gen_id }}--image1 {
      aspect-ratio: {{ block.settings.image1_aspect_ratio }};
      width: {{ block.settings.image1_width }}%;
    }

    .ai-image-comparison-image-wrapper-{{ ai_gen_id }}--image2 {
      aspect-ratio: {{ block.settings.image2_aspect_ratio }};
      width: {{ block.settings.image2_width }}%;
    }
  }
{% endstyle %}

<image-comparison-{{ ai_gen_id }}
  class="ai-image-comparison-{{ ai_gen_id }} color-{{ block.settings.section_color_scheme }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-comparison-container-{{ ai_gen_id }} color-{{ block.settings.container_color_scheme }}">
    <div class="ai-image-comparison-wrapper-{{ ai_gen_id }}">
      <div class="ai-image-comparison-desktop-{{ ai_gen_id }}">
        <div class="ai-image-comparison-image-wrapper-{{ ai_gen_id }} ai-image-comparison-image-wrapper-{{ ai_gen_id }}--image1">
          {% if block.settings.image1 %}
            <img
              src="{{ block.settings.image1 | image_url: width: 1200 }}"
              alt="{{ block.settings.image1.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image1.width }}"
              height="{{ block.settings.image1.height }}"
              class="ai-image-comparison-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-image-comparison-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        <div class="ai-image-comparison-image-wrapper-{{ ai_gen_id }} ai-image-comparison-image-wrapper-{{ ai_gen_id }}--image2">
          {% if block.settings.image2 %}
            <img
              src="{{ block.settings.image2 | image_url: width: 1200 }}"
              alt="{{ block.settings.image2.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image2.width }}"
              height="{{ block.settings.image2.height }}"
              class="ai-image-comparison-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-image-comparison-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-image-comparison-mobile-{{ ai_gen_id }}">
        <div class="ai-image-comparison-carousel-{{ ai_gen_id }}" data-carousel>
          <div class="ai-image-comparison-slide-{{ ai_gen_id }}">
            <div class="ai-image-comparison-image-wrapper-{{ ai_gen_id }}">
              {% if block.settings.image1 %}
                <img
                  src="{{ block.settings.image1 | image_url: width: 800 }}"
                  alt="{{ block.settings.image1.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image1.width }}"
                  height="{{ block.settings.image1.height }}"
                  class="ai-image-comparison-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-image-comparison-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          </div>

          <div class="ai-image-comparison-slide-{{ ai_gen_id }}">
            <div class="ai-image-comparison-image-wrapper-{{ ai_gen_id }}">
              {% if block.settings.image2 %}
                <img
                  src="{{ block.settings.image2 | image_url: width: 800 }}"
                  alt="{{ block.settings.image2.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image2.width }}"
                  height="{{ block.settings.image2.height }}"
                  class="ai-image-comparison-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-image-comparison-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          </div>
        </div>

        <div class="ai-image-comparison-dots-{{ ai_gen_id }}">
          <button
            class="ai-image-comparison-dot-{{ ai_gen_id }} active"
            data-index="0"
            aria-label="Go to image 1"
          ></button>
          <button
            class="ai-image-comparison-dot-{{ ai_gen_id }}"
            data-index="1"
            aria-label="Go to image 2"
          ></button>
        </div>
      </div>
    </div>
  </div>
</image-comparison-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageComparison{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.startX = 0;
        this.currentX = 0;
        this.isDragging = false;
      }

      connectedCallback() {
        this.carousel = this.querySelector('[data-carousel]');
        this.dots = this.querySelectorAll('.ai-image-comparison-dot-{{ ai_gen_id }}');
        
        if (!this.carousel) return;

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.carousel.addEventListener('touchstart', this.handleTouchStart.bind(this), { passive: true });
        this.carousel.addEventListener('touchmove', this.handleTouchMove.bind(this), { passive: true });
        this.carousel.addEventListener('touchend', this.handleTouchEnd.bind(this));

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const index = parseInt(e.target.dataset.index);
            this.goToSlide(index);
          });
        });
      }

      handleTouchStart(e) {
        this.startX = e.touches[0].clientX;
        this.isDragging = true;
      }

      handleTouchMove(e) {
        if (!this.isDragging) return;
        this.currentX = e.touches[0].clientX;
      }

      handleTouchEnd() {
        if (!this.isDragging) return;
        this.isDragging = false;

        const diff = this.startX - this.currentX;
        const threshold = 50;

        if (Math.abs(diff) > threshold) {
          if (diff > 0 && this.currentIndex < 1) {
            this.goToSlide(this.currentIndex + 1);
          } else if (diff < 0 && this.currentIndex > 0) {
            this.goToSlide(this.currentIndex - 1);
          }
        }

        this.startX = 0;
        this.currentX = 0;
      }

      goToSlide(index) {
        this.currentIndex = index;
        const offset = -index * 100;
        this.carousel.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('image-comparison-{{ ai_gen_id }}', ImageComparison{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
