{% doc %}
  @prompt
    Generate a comparison chart that fits all aspects of my theme, also include the choice to choose how many columns there are, Have the option for the Feauture name to be adjusted to be centered in the middle of the column as well as on the left, I want to be able to adjust the container padding with just a number. Also I meant being able to adjust the feature names inside the chart, for example if I want hand created design to be centered I have the option to do so. For mobile it should be a smaller form factor. And the title of the chart should be a fixed position white you can swipe on the chart, I also want control over the width of the feature column. I also want control over every silgle column as well. on mobile the chart shouldnt have scroll it should be able to show everything
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-chart-{{ ai_gen_id }} {
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-comparison-chart__title-{{ ai_gen_id }} {
    text-align: {{ block.settings.title_alignment }};
    margin-bottom: 30px;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
  }

  .ai-comparison-chart__wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-comparison-chart__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.feature_column_width }}px repeat({{ block.settings.columns }}, 1fr);
    gap: 0;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-comparison-chart__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    border-right: 1px solid {{ block.settings.border_color }};
    border-bottom: 1px solid {{ block.settings.border_color }};
    display: flex;
    align-items: center;
    min-height: 60px;
  }

  .ai-comparison-chart__cell-{{ ai_gen_id }}:nth-child({{ block.settings.columns | plus: 1 }}n) {
    border-right: none;
  }

  .ai-comparison-chart__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_bg_color }};
    color: {{ block.settings.header_text_color }};
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
    justify-content: {{ block.settings.header_alignment }};
    text-align: {{ block.settings.header_alignment }};
  }

  .ai-comparison-chart__feature-{{ ai_gen_id }} {
    background-color: {{ block.settings.feature_bg_color }};
    color: {{ block.settings.feature_text_color }};
    font-weight: 500;
    font-size: {{ block.settings.feature_font_size }}px;
  }

  .ai-comparison-chart__value-{{ ai_gen_id }} {
    background-color: {{ block.settings.value_bg_color }};
    color: {{ block.settings.value_text_color }};
    justify-content: center;
    text-align: center;
    font-size: {{ block.settings.value_font_size }}px;
  }

  .ai-comparison-chart__checkmark-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    color: {{ block.settings.checkmark_color }};
  }

  .ai-comparison-chart__cross-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    color: {{ block.settings.cross_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-chart__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
      border: none;
    }

    .ai-comparison-chart__cell-{{ ai_gen_id }} {
      border: none;
      border-bottom: 1px solid {{ block.settings.border_color }};
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }

    .ai-comparison-chart__cell-{{ ai_gen_id }}:last-child {
      border-bottom: none;
    }

    .ai-comparison-chart__mobile-column-{{ ai_gen_id }} {
      border: 1px solid {{ block.settings.border_color }};
      border-radius: {{ block.settings.border_radius }}px;
      overflow: hidden;
      margin-bottom: 20px;
    }

    .ai-comparison-chart__mobile-column-{{ ai_gen_id }}:last-child {
      margin-bottom: 0;
    }

    .ai-comparison-chart__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-comparison-chart__mobile-column-{{ ai_gen_id }} {
      display: contents;
    }
  }
{% endstyle %}

<div class="ai-comparison-chart-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank %}
    <h2 class="ai-comparison-chart__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
  {% endif %}

  <div class="ai-comparison-chart__wrapper-{{ ai_gen_id }}">
    <div class="ai-comparison-chart__container-{{ ai_gen_id }}">
      <div class="ai-comparison-chart__mobile-column-{{ ai_gen_id }}">
        <div class="ai-comparison-chart__cell-{{ ai_gen_id }} ai-comparison-chart__header-{{ ai_gen_id }}">
          {{ block.settings.feature_column_header }}
        </div>

        {% for i in (1..10) %}
          {% liquid
            assign feature_key = 'feature_' | append: i
            assign feature_text_key = 'feature_' | append: i | append: '_text'
            assign feature_align_key = 'feature_' | append: i | append: '_alignment'
            
            assign feature_enabled = block.settings[feature_key]
            assign feature_text = block.settings[feature_text_key]
            assign feature_alignment = block.settings[feature_align_key]
          %}

          {% if feature_enabled and feature_text != blank %}
            <div class="ai-comparison-chart__cell-{{ ai_gen_id }} ai-comparison-chart__feature-{{ ai_gen_id }}" style="justify-content: {{ feature_alignment }}; text-align: {{ feature_alignment }};">
              {{ feature_text }}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% for col in (1..block.settings.columns) %}
        <div class="ai-comparison-chart__mobile-column-{{ ai_gen_id }}">
          {% liquid
            assign col_header_key = 'column_' | append: col | append: '_header'
            assign col_header = block.settings[col_header_key]
          %}

          <div class="ai-comparison-chart__cell-{{ ai_gen_id }} ai-comparison-chart__header-{{ ai_gen_id }}">
            {{ col_header }}
          </div>

          {% for i in (1..10) %}
            {% liquid
              assign feature_key = 'feature_' | append: i
              assign value_key = 'column_' | append: col | append: '_feature_' | append: i
              
              assign feature_enabled = block.settings[feature_key]
              assign value = block.settings[value_key]
            %}

            {% if feature_enabled %}
              <div class="ai-comparison-chart__cell-{{ ai_gen_id }} ai-comparison-chart__value-{{ ai_gen_id }}">
                {% if value == 'check' %}
                  <svg class="ai-comparison-chart__checkmark-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                {% elsif value == 'cross' %}
                  <svg class="ai-comparison-chart__cross-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                  </svg>
                {% else %}
                  {{ value }}
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

