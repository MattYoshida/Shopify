    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Horizontal padding",
      "min": 12,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "hover_lift",
      "label": "Hover lift effect",
      "min": -2,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": -1
    }
  ],
  "presets": [
    {
      "name": "Collection button"
    }
  ]
}
{% endschema %}