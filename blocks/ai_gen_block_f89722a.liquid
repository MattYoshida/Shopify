{% doc %}
  @prompt
      A view all collections button in the featured collection that says best sellers, I dont want the button to seay best sellers I want it to say View Collections
      {% enddoc %}
      {% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
      
      {% style %}
        .ai-view-collections-button-{{ ai_gen_id }} {
            display: flex;
                justify-content: {{ block.settings.alignment }};
                    align-items: center;
                        padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
                            width: 100%;
                              }
                              
                                .ai-view-collections-button-link-{{ ai_gen_id }} {
                                    display: inline-flex;
                                        align-items: center;
                                            justify-content: center;
                                                gap: 8px;
                                                    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
                                                        background-color: {{ block.settings.button_color }};
                                                            color: {{ block.settings.button_text_color }};
                                                                text-decoration: none;
                                                                    border: 2px solid {{ block.settings.button_border_color }};
                                                                        font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
                                                                            font-weight: {{ settings.buttons_font_weight }};
                                                                                font-size: {{ block.settings.button_font_size }}px;
                                                                                    text-transform: {% if settings.buttons_transform == 'uppercase' %}uppercase{% elsif settings.buttons_transform == 'lowercase' %}lowercase{% elsif settings.buttons_transform == 'capitalize' %}capitalize{% else %}none{% endif %};
                                                                                        letter-spacing: {{ settings.buttons_letter_spacing | times: 0.01 }}em;
                                                                                            transition: all 0.3s ease;
                                                                                                cursor: pointer;
                                                                                                    {% if settings.buttons_corner_radius == 'square' %}
                                                                                                          border-radius: 0;
                                                                                                              {% elsif settings.buttons_corner_radius == 'slightly' %}
                                                                                                                    border-radius: 4px;
                                                                                                                        {% elsif settings.buttons_corner_radius == 'soft-pill' %}
                                                                                                                              border-radius: 12px;
                                                                                                                                  {% elsif settings.buttons_corner_radius == 'round' %}
                                                                                                                                        border-radius: 50px;
                                                                                                                                            {% endif %}
                                                                                                                                              }
                                                                                                                                              
                                                                                                                                                .ai-view-collections-button-link-{{ ai_gen_id }}:hover {
                                                                                                                                                    background-color: {{ block.settings.button_hover_color }};
                                                                                                                                                        color: {{ block.settings.button_hover_text_color }};
                                                                                                                                                            border-color: {{ block.settings.button_hover_border_color }};
                                                                                                                                                                transform: translateY(-2px);
                                                                                                                                                                  }
                                                                                                                                                                  
                                                                                                                                                                    .ai-view-collections-button-icon-{{ ai_gen_id }} {
                                                                                                                                                                        width: {{ block.settings.icon_size }}px;
                                                                                                                                                                            height: {{ block.settings.icon_size }}px;
                                                                                                                                                                                transition: transform 0.3s ease;
                                                                                                                                                                                  }
                                                                                                                                                                                  
                                                                                                                                                                                    .ai-view-collections-button-link-{{ ai_gen_id }}:hover .ai-view-collections-button-icon-{{ ai_gen_id }} {
                                                                                                                                                                                        transform: translateX(4px);
                                                                                                                                                                                          }
                                                                                                                                                                                          
                                                                                                                                                                                            @media screen and (max-width: 749px) {
                                                                                                                                                                                                .ai-view-collections-button-{{ ai_gen_id }} {
                                                                                                                                                                                                      justify-content: {{ block.settings.mobile_alignment }};
                                                                                                                                                                                                            padding: {{ block.settings.mobile_section_padding_top }}px 0 {{ block.settings.mobile_section_padding_bottom }}px;
                                                                                                                                                                                                                }
                                                                                                                                                                                                                
                                                                                                                                                                                                                    .ai-view-collections-button-link-{{ ai_gen_id }} {
                                                                                                                                                                                                                          font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
                                                                                                                                                                                                                                padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                      }
                                                                                                                                                                                                                                      {% endstyle %}
                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                      <div
                                                                                                                                                                                                                                        class="ai-view-collections-button-{{ ai_gen_id }}"
                                                                                                                                                                                                                                          {{ block.shopify_attributes }}
                                                                                                                                                                                                                                          >
                                                                                                                                                                                                                                            <a
                                                                                                                                                                                                                                                href="{{ block.settings.button_link }}"
                                                                                                                                                                                                                                                    class="ai-view-collections-button-link-{{ ai_gen_id }}"
                                                                                                                                                                                                                                                        {% if block.settings.button_link == blank %}
                                                                                                                                                                                                                                                              role="button"
                                                                                                                                                                                                                                                                    aria-disabled="true"
                                                                                                                                                                                                                                                                        {% endif %}
                                                                                                                                                                                                                                                                          >
                                                                                                                                                                                                                                                                              <span>{{ block.settings.button_text }}</span>
                                                                                                                                                                                                                                                                                  {% if block.settings.show_icon %}
                                                                                                                                                                                                                                                                                        <svg
                                                                                                                                                                                                                                                                                                class="ai-view-collections-button-icon-{{ ai_gen_id }}"
                                                                                                                                                                                                                                                                                                        xmlns="http://www.w3.org/2000/svg"
                                                                                                                                                                                                                                                                                                                viewBox="0 0 24 24"
                                                                                                                                                                                                                                                                                                                        fill="none"
                                                                                                                                                                                                                                                                                                                                stroke="currentColor"
                                                                                                                                                                                                                                                                                                                                        stroke-width="2"
                                                                                                                                                                                                                                                                                                                                                stroke-linecap="round"
                                                                                                                                                                                                                                                                                                                                                        stroke-linejoin="round"
                                                                                                                                                                                                                                                                                                                                                              >
                                                                                                                                                                                                                                                                                                                                                                      <path d="M5 12h14"></path>
                                                                                                                                                                                                                                                                                                                                                                              <path d="m12 5 7 7-7 7"></path>
                                                                                                                                                                                                                                                                                                                                                                                    </svg>
                                                                                                                                                                                                                                                                                                                                                                                        {% endif %}
                                                                                                                                                                                                                                                                                                                                                                                          </a>
                                                                                                                                                                                                                                                                                                                                                                                          </div>
                                                                                                                                                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                                                                                                                                                          {% schema %}
                                                                                                                                                                                                                                                                                                                                                                                          {
                                                                                                                                                                                                                                                                                                                                                                                            "name": "Collections button",
                                                                                                                                                                                                                                                                                                                                                                                              "settings": [
                                                                                                                                                                                                                                                                                                                                                                                                  {
                                                                                                                                                                                                                                                                                                                                                                                                        "type": "header",
                                                                                                                                                                                                                                                                                                                                                                                                              "content": "Button content"
                                                                                                                                                                                                                                                                                                                                                                                                                  },
                                                                                                                                                                                                                                                                                                                                                                                                                      {
                                                                                                                                                                                                                                                                                                                                                                                                                            "type": "text",
                                                                                                                                                                                                                                                                                                                                                                                                                                  "id": "button_text",
                                                                                                                                                                                                                                                                                                                                                                                                                                        "label": "Button text",
                                                                                                                                                                                                                                                                                                                                                                                                                                              "default": "View Collections"
                                                                                                                                                                                                                                                                                                                                                                                                                                                  },
                                                                                                                                                                                                                                                                                                                                                                                                                                                      {
                                                                                                                                                                                                                                                                                                                                                                                                                                                            "type": "url",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                  "id": "button_link",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "label": "Button link"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "type": "checkbox",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "id": "show_icon",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  "label": "Show arrow icon",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "default": true
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "type": "header",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "content": "Button style"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          "type": "range",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "id": "button_font_size",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "min": 12,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "max": 24,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  "step": 1,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "unit": "px",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "label": "Font size",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "default": 16
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  "type": "range",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "id": "button_padding_vertical",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "min": 8,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "max": 24,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          "step": 2,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "unit": "px",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "label": "Vertical padding",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "default": 14
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          "type": "range",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "id": "button_padding_horizontal",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "min": 16,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "max": 48,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  "step": 4,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "unit": "px",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "label": "Horizontal padding",
