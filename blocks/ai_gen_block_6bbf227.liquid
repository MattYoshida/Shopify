{% doc %}
  @prompt
    An image with text block with the ability to choose what side the image is on. also the abilty to change the aspect ratio of the image. I also want text customizability, I want to be able to choose the position of the image if i want it flush left or lush right or in the center like it is now, I also want to be able to adjust the location of the text , I also want to be able to edit wether I want the text as well as the heading to be shown on mobile or desktop. I also want to be able to adjust the position of where the text is, so the spacing between the image and the text. Also I want a large variablility in horizontal padding up to 300px
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.image_position }};
    align-items: {{ block.settings.vertical_alignment }};
    gap: {{ block.settings.spacing }}px;
    padding-left: {{ block.settings.horizontal_padding }}px;
    padding-right: {{ block.settings.horizontal_padding }}px;
    padding-top: {{ block.settings.vertical_padding }}px;
    padding-bottom: {{ block.settings.vertical_padding }}px;
    max-width: 100%;
  }

  .ai-image-text-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    display: flex;
    justify-content: {{ block.settings.image_alignment }};
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    object-fit: cover;
    {% if block.settings.image_aspect_ratio != 'adapt' %}
      aspect-ratio: {{ block.settings.image_aspect_ratio }};
    {% endif %}
  }

  .ai-image-text-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    {% if block.settings.image_aspect_ratio != 'adapt' %}
      aspect-ratio: {{ block.settings.image_aspect_ratio }};
    {% else %}
      min-height: 400px;
    {% endif %}
  }

  .ai-image-text-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.text_vertical_alignment }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-text-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
  }

  .ai-image-text-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.spacing_mobile }}px;
      padding-left: {{ block.settings.horizontal_padding_mobile }}px;
      padding-right: {{ block.settings.horizontal_padding_mobile }}px;
    }

    .ai-image-text-image-wrapper-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    {% if block.settings.hide_heading_mobile %}
      .ai-image-text-heading-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}

    {% if block.settings.hide_text_mobile %}
      .ai-image-text-text-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}

    .ai-image-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-image-text-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }
  }

  @media screen and (min-width: 750px) {
    {% if block.settings.hide_heading_desktop %}
      .ai-image-text-heading-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}

    {% if block.settings.hide_text_desktop %}
      .ai-image-text-text-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-image-text-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-{{ ai_gen_id }}">
    <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-image-text-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-image-text-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-image-text-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-image-text-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-image-text-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with text",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 1000,
      "max": 2000,
      "step": 10,
      "unit": "px",
      "label": "Container width",
      "default": 1410
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "row",
          "label": "Left"
        },
        {
          "value": "row-reverse",
          "label": "Right"
        }
      ],
      "default": "row"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Spacing between image and text",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Spacing on mobile",
      "default": 20
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "min": 0,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 50
    },
    {
      "type": "range",
      "id": "horizontal_padding_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Horizontal padding on mobile",
      "default": 20
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Vertical padding",
      "default": 50
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "1/1",
          "label": "1:1"
        },
        {
          "value": "3/4",
          "label": "3:4"
        },
        {
          "value": "4/3",
          "label": "4:3"
        },
        {
          "value": "16/9",
          "label": "16:9"
        }
      ],
      "default": "adapt"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Image width",
      "default": 50
    },
    {
      "type": "select",
      "id": "image_alignment",
      "label": "Image alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Image with text</p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_vertical_alignment",
      "label": "Text vertical position",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 14,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Heading size on mobile",
      "default": 24
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Heading spacing",
      "default": 20
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size on mobile",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Mobile visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_heading_mobile",
      "label": "Hide heading on mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_text_mobile",
      "label": "Hide text on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Desktop visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_heading_desktop",
      "label": "Hide heading on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_text_desktop",
      "label": "Hide text on desktop",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Image with text"
    }
  ]
}
{% endschema %}
