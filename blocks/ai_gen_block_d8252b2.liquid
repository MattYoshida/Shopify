{% doc %}
  @prompt
    Generate a comparison chart that fits all aspects of my theme, also include the choice to choose how many columns there are, Have the option for the Feauture name to be adjusted to be centered in the middle of the column as well as on the left, I want to be able to adjust the container padding with just a number. Also I meant being able to adjust the feature names inside the chart, for example if I want hand created design to be centered I have the option to do so. For mobile it should be a smaller form factor. And the title of the chart should be a fixed position white you can swipe on the chart, I also want control over the width of the feature column 
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-chart-{{ ai_gen_id }} {
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-comparison-chart__title-{{ ai_gen_id }} {
    text-align: {{ block.settings.title_alignment }};
    margin-bottom: 30px;
    color: {{ block.settings.title_color }};
    font-size: 32px;
  }

  .ai-comparison-chart__wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ai-comparison-chart__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    min-width: 600px;
  }

  .ai-comparison-chart__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_bg_color }};
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .ai-comparison-chart__header-cell-{{ ai_gen_id }} {
    padding: 20px 15px;
    text-align: center;
    font-weight: 600;
    color: {{ block.settings.header_text_color }};
    border: 1px solid {{ block.settings.border_color }};
    font-size: 16px;
  }

  .ai-comparison-chart__header-cell-{{ ai_gen_id }}:first-child {
    text-align: {{ block.settings.feature_name_alignment }};
    background-color: {{ block.settings.feature_column_bg }};
    position: sticky;
    left: 0;
    z-index: 11;
    width: {{ block.settings.feature_column_width }}px;
    min-width: {{ block.settings.feature_column_width }}px;
    max-width: {{ block.settings.feature_column_width }}px;
  }

  .ai-comparison-chart__row-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-comparison-chart__row-{{ ai_gen_id }}:nth-child(even) {
    background-color: {{ block.settings.row_even_bg }};
  }

  .ai-comparison-chart__row-{{ ai_gen_id }}:nth-child(odd) {
    background-color: {{ block.settings.row_odd_bg }};
  }

  .ai-comparison-chart__cell-{{ ai_gen_id }} {
    padding: 15px;
    text-align: center;
    border: 1px solid {{ block.settings.border_color }};
    color: {{ block.settings.text_color }};
    font-size: 14px;
  }

  .ai-comparison-chart__cell-{{ ai_gen_id }}:first-child {
    font-weight: 500;
    text-align: {{ block.settings.feature_name_alignment }};
    background-color: {{ block.settings.feature_column_bg }};
    position: sticky;
    left: 0;
    z-index: 5;
    width: {{ block.settings.feature_column_width }}px;
    min-width: {{ block.settings.feature_column_width }}px;
    max-width: {{ block.settings.feature_column_width }}px;
  }

  .ai-comparison-chart__icon-{{ ai_gen_id }} {
    display: inline-block;
    width: 20px;
    height: 20px;
  }

  .ai-comparison-chart__icon-{{ ai_gen_id }}--check {
    color: {{ block.settings.check_color }};
  }

  .ai-comparison-chart__icon-{{ ai_gen_id }}--cross {
    color: {{ block.settings.cross_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-chart-{{ ai_gen_id }} {
      padding: {{ block.settings.container_padding | times: 0.5 }}px;
    }

    .ai-comparison-chart__title-{{ ai_gen_id }} {
      font-size: 24px;
      margin-bottom: 20px;
    }

    .ai-comparison-chart__table-{{ ai_gen_id }} {
      min-width: 500px;
      font-size: 13px;
    }

    .ai-comparison-chart__header-cell-{{ ai_gen_id }} {
      padding: 12px 8px;
      font-size: 14px;
    }

    .ai-comparison-chart__header-cell-{{ ai_gen_id }}:first-child {
      width: {{ block.settings.feature_column_width | times: 0.7 }}px;
      min-width: {{ block.settings.feature_column_width | times: 0.7 }}px;
      max-width: {{ block.settings.feature_column_width | times: 0.7 }}px;
    }

    .ai-comparison-chart__cell-{{ ai_gen_id }} {
      padding: 10px 8px;
      font-size: 13px;
    }

    .ai-comparison-chart__cell-{{ ai_gen_id }}:first-child {
      width: {{ block.settings.feature_column_width | times: 0.7 }}px;
      min-width: {{ block.settings.feature_column_width | times: 0.7 }}px;
      max-width: {{ block.settings.feature_column_width | times: 0.7 }}px;
    }

    .ai-comparison-chart__icon-{{ ai_gen_id }} {
      width: 16px;
      height: 16px;
    }
  }
{% endstyle %}

<div class="ai-comparison-chart-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank %}
    <h2 class="ai-comparison-chart__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
  {% endif %}

  <div class="ai-comparison-chart__wrapper-{{ ai_gen_id }}">
    <table class="ai-comparison-chart__table-{{ ai_gen_id }}">
      <thead class="ai-comparison-chart__header-{{ ai_gen_id }}">
        <tr>
          <th class="ai-comparison-chart__header-cell-{{ ai_gen_id }}">{{ block.settings.feature_column_title }}</th>
          {% if block.settings.columns >= 1 and block.settings.column_1_title != blank %}
            <th class="ai-comparison-chart__header-cell-{{ ai_gen_id }}">{{ block.settings.column_1_title }}</th>
          {% endif %}
          {% if block.settings.columns >= 2 and block.settings.column_2_title != blank %}
            <th class="ai-comparison-chart__header-cell-{{ ai_gen_id }}">{{ block.settings.column_2_title }}</th>
          {% endif %}
          {% if block.settings.columns >= 3 and block.settings.column_3_title != blank %}
            <th class="ai-comparison-chart__header-cell-{{ ai_gen_id }}">{{ block.settings.column_3_title }}</th>
          {% endif %}
          {% if block.settings.columns >= 4 and block.settings.column_4_title != blank %}
            <th class="ai-comparison-chart__header-cell-{{ ai_gen_id }}">{{ block.settings.column_4_title }}</th>
          {% endif %}
        </tr>
      </thead>
      <tbody>
        {% for i in (1..10) %}
          {% liquid
            assign feature_key = 'feature_' | append: i | append: '_name'
            assign feature_name = block.settings[feature_key]
            
            if feature_name != blank
              assign col1_key = 'feature_' | append: i | append: '_col1'
              assign col2_key = 'feature_' | append: i | append: '_col2'
              assign col3_key = 'feature_' | append: i | append: '_col3'
              assign col4_key = 'feature_' | append: i | append: '_col4'
              
              assign col1_value = block.settings[col1_key]
              assign col2_value = block.settings[col2_key]
              assign col3_value = block.settings[col3_key]
              assign col4_value = block.settings[col4_key]
            endif
          %}
          
          {% if feature_name != blank %}
            <tr class="ai-comparison-chart__row-{{ ai_gen_id }}">
              <td class="ai-comparison-chart__cell-{{ ai_gen_id }}">{{ feature_name }}</td>
              
              {% if block.settings.columns >= 1 %}
                <td class="ai-comparison-chart__cell-{{ ai_gen_id }}">
                  {% if col1_value == 'check' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__icon-{{ ai_gen_id }}--check">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                  {% elsif col1_value == 'cross' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__icon-{{ ai_gen_id }}--cross">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                  {% else %}
                    {{ col1_value }}
                  {% endif %}
                </td>
              {% endif %}
              
              {% if block.settings.columns >= 2 %}
                <td class="ai-comparison-chart__cell-{{ ai_gen_id }}">
                  {% if col2_value == 'check' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__icon-{{ ai_gen_id }}--check">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                  {% elsif col2_value == 'cross' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__icon-{{ ai_gen_id }}--cross">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                  {% else %}
                    {{ col2_value }}
                  {% endif %}
                </td>
              {% endif %}
              
              {% if block.settings.columns >= 3 %}
                <td class="ai-comparison-chart__cell-{{ ai_gen_id }}">
                  {% if col3_value == 'check' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__icon-{{ ai_gen_id }}--check">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                  {% elsif col3_value == 'cross' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__icon-{{ ai_gen_id }}--cross">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                  {% else %}
                    {{ col3_value }}
                  {% endif %}
                </td>
              {% endif %}
              
              {% if block.settings.columns >= 4 %}
                <td class="ai-comparison-chart__cell-{{ ai_gen_id }}">
                  {% if col4_value == 'check' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__icon-{{ ai_gen_id }}--check">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                  {% elsif col4_value == 'cross' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__icon-{{ ai_gen_id }}--cross">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                  {% else %}
                    {{ col4_value }}
                  {% endif %}
                </td>
              {% endif %}
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

{% schema %}
