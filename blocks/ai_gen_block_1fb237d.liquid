{% doc %}
  @prompt
    I want two image side by side i can shoose the apsect ratio and they are centered, On mobile I want to be able to swipe between the two images. and I want the little gray circle indicator on the bottom to show which image i am on, the images are side by side but i dont see the image selector as an opaque circle which becomes a darker circle when the image 1 is slected and goes to teh second whne image 2 is seletgted, I want control over the theme as well, I want to be able to create the backround theme
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dual-image-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-dual-image__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.gap }}px;
  }

  .ai-dual-image__wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.image_width }}px;
    flex-shrink: 0;
  }

  .ai-dual-image__image-container-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    {% if block.settings.aspect_ratio == 'adapt' %}
      aspect-ratio: auto;
    {% elsif block.settings.aspect_ratio == '1/1' %}
      aspect-ratio: 1 / 1;
    {% elsif block.settings.aspect_ratio == '3/4' %}
      aspect-ratio: 3 / 4;
    {% elsif block.settings.aspect_ratio == '4/3' %}
      aspect-ratio: 4 / 3;
    {% elsif block.settings.aspect_ratio == '16/9' %}
      aspect-ratio: 16 / 9;
    {% elsif block.settings.aspect_ratio == '9/16' %}
      aspect-ratio: 9 / 16;
    {% endif %}
  }

  .ai-dual-image__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-dual-image__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-dual-image__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-dual-image__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-dual-image__slider-container-{{ ai_gen_id }} {
    display: none;
  }

  .ai-dual-image__slider-{{ ai_gen_id }} {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .ai-dual-image__slider-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-dual-image__slide-{{ ai_gen_id }} {
    flex: 0 0 100%;
    scroll-snap-align: start;
  }

  .ai-dual-image__indicators-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
    padding: 0 16px;
  }

  .ai-dual-image__indicator-{{ ai_gen_id }} {
    width: {{ block.settings.indicator_size }}px;
    height: {{ block.settings.indicator_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.indicator_color }};
    transition: background-color 0.3s ease;
    cursor: pointer;
  }

  .ai-dual-image__indicator-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.indicator_active_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-dual-image__container-{{ ai_gen_id }} {
      display: none;
    }

    .ai-dual-image__slider-container-{{ ai_gen_id }} {
      display: block;
    }
  }
{% endstyle %}

<div class="ai-dual-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-dual-image__container-{{ ai_gen_id }}">
    <div class="ai-dual-image__wrapper-{{ ai_gen_id }}">
      <div class="ai-dual-image__image-container-{{ ai_gen_id }}">
        {% if block.settings.image_1 %}
          <img
            src="{{ block.settings.image_1 | image_url: width: 1500 }}"
            alt="{{ block.settings.image_1.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_1.width }}"
            height="{{ block.settings.image_1.height }}"
            class="ai-dual-image__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-dual-image__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-dual-image__empty-state-{{ ai_gen_id }}">
              Add first image
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-dual-image__wrapper-{{ ai_gen_id }}">
      <div class="ai-dual-image__image-container-{{ ai_gen_id }}">
        {% if block.settings.image_2 %}
          <img
            src="{{ block.settings.image_2 | image_url: width: 1500 }}"
            alt="{{ block.settings.image_2.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_2.width }}"
            height="{{ block.settings.image_2.height }}"
            class="ai-dual-image__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-dual-image__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-dual-image__empty-state-{{ ai_gen_id }}">
              Add second image
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <dual-image-slider-{{ ai_gen_id }} class="ai-dual-image__slider-container-{{ ai_gen_id }}">
    <div class="ai-dual-image__slider-{{ ai_gen_id }}">
      <div class="ai-dual-image__slide-{{ ai_gen_id }}">
        <div class="ai-dual-image__image-container-{{ ai_gen_id }}">
          {% if block.settings.image_1 %}
            <img
              src="{{ block.settings.image_1 | image_url: width: 1500 }}"
              alt="{{ block.settings.image_1.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image_1.width }}"
              height="{{ block.settings.image_1.height }}"
              class="ai-dual-image__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-dual-image__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-dual-image__empty-state-{{ ai_gen_id }}">
                Add first image
              </div>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-dual-image__slide-{{ ai_gen_id }}">
        <div class="ai-dual-image__image-container-{{ ai_gen_id }}">
          {% if block.settings.image_2 %}
            <img
              src="{{ block.settings.image_2 | image_url: width: 1500 }}"
              alt="{{ block.settings.image_2.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image_2.width }}"
              height="{{ block.settings.image_2.height }}"
              class="ai-dual-image__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-dual-image__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-dual-image__empty-state-{{ ai_gen_id }}">
                Add second image
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="ai-dual-image__indicators-{{ ai_gen_id }}">
      <div class="ai-dual-image__indicator-{{ ai_gen_id }} active" data-index="0"></div>
      <div class="ai-dual-image__indicator-{{ ai_gen_id }}" data-index="1"></div>
    </div>
  </dual-image-slider-{{ ai_gen_id }}>
</div>

<script>
  (function() {
    class DualImageSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.slider = this.querySelector('.ai-dual-image__slider-{{ ai_gen_id }}');
        this.indicators = this.querySelectorAll('.ai-dual-image__indicator-{{ ai_gen_id }}');
        
        if (!this.slider || !this.indicators.length) return;

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.slider.addEventListener('scroll', () => {
          this.updateIndicators();
        });

        this.indicators.forEach((indicator) => {
          indicator.addEventListener('click', () => {
            const index = parseInt(indicator.dataset.index);
            this.scrollToSlide(index);
          });
        });
      }

      updateIndicators() {
        const scrollLeft = this.slider.scrollLeft;
        const slideWidth = this.slider.offsetWidth;
        const currentIndex = Math.round(scrollLeft / slideWidth);

        this.indicators.forEach((indicator, index) => {
          if (index === currentIndex) {
            indicator.classList.add('active');
          } else {
            indicator.classList.remove('active');
          }
        });
      }

      scrollToSlide(index) {
        const slideWidth = this.slider.offsetWidth;
        this.slider.scrollTo({
          left: slideWidth * index,
          behavior: 'smooth'
        });
      }
    }

    customElements.define('dual-image-slider-{{ ai_gen_id }}', DualImageSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Dual images",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "First image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Second image"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "1/1",
          "label": "Square (1:1)"
        },
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "16/9",
          "label": "Widescreen (16:9)"
        },
        {
          "value": "9/16",
          "label": "Tall (9:16)"
        }
      ],
      "default": "1/1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 200,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Image width",
      "default": 500
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Gap between images",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Mobile indicators"
    },
    {
      "type": "range",
      "id": "indicator_size",
      "min": 6,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 10
    },
    {
      "type": "color",
      "id": "indicator_color",
      "label": "Inactive color",
      "default": "rgba(0, 0, 0, 0.2)"
    },
    {
      "type": "color",
      "id": "indicator_active_color",
      "label": "Active color",
      "default": "rgba(0, 0, 0, 0.6)"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Dual images"
    }
  ]
}
{% endschema %}
