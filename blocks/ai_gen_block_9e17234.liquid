{% doc %}
  @prompt
    Generate a comparison chart that fits all aspects of my theme, also include the choice to choose how many columns there are, Have the option for the Feauture name to be adjusted to be centered in the middle of the column as well as on the left, I want to be able to adjust the container padding with just a number. Also I meant being able to adjust the feature names inside the chart, for example if I want hand created design to be centered I have the option to do so
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-chart-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-comparison-chart__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: 0;
    padding: {{ block.settings.container_padding }}px;
  }

  .ai-comparison-chart__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
  }

  .ai-comparison-chart__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px 0;
    font-size: {{ block.settings.heading_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-comparison-chart__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0;
    font-size: {{ block.settings.subheading_size }}px;
    opacity: 0.8;
  }

  .ai-comparison-chart__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    min-width: 600px;
  }

  .ai-comparison-chart__table-{{ ai_gen_id }} thead th {
    background-color: {{ block.settings.header_bg_color }};
    color: {{ block.settings.header_text_color }};
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-weight: 500;
    text-transform: uppercase;
    font-size: {{ block.settings.header_font_size }}px;
    letter-spacing: 0.5px;
    border: 1px solid {{ block.settings.border_color }};
  }

  .ai-comparison-chart__table-{{ ai_gen_id }} thead th:first-child {
    text-align: left;
    background-color: transparent;
    border-left: none;
    border-top: none;
  }

  .ai-comparison-chart__table-{{ ai_gen_id }} tbody tr {
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-comparison-chart__table-{{ ai_gen_id }} tbody tr:hover {
    background-color: {{ block.settings.row_hover_color }};
  }

  .ai-comparison-chart__table-{{ ai_gen_id }} tbody td {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.body_font_size }}px;
    border-left: 1px solid {{ block.settings.border_color }};
    border-right: 1px solid {{ block.settings.border_color }};
  }

  .ai-comparison-chart__table-{{ ai_gen_id }} tbody td:first-child {
    font-weight: 500;
    border-left: none;
  }

  .ai-comparison-chart__table-{{ ai_gen_id }} tbody td:last-child {
    border-right: none;
  }

  .ai-comparison-chart__feature-left-{{ ai_gen_id }} {
    text-align: left;
  }

  .ai-comparison-chart__feature-center-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-comparison-chart__icon-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ai-comparison-chart__icon-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .ai-comparison-chart__checkmark-{{ ai_gen_id }} {
    color: {{ block.settings.checkmark_color }};
  }

  .ai-comparison-chart__cross-{{ ai_gen_id }} {
    color: {{ block.settings.cross_color }};
  }

  .ai-comparison-chart__highlight-{{ ai_gen_id }} {
    background-color: {{ block.settings.highlight_bg_color }};
    position: relative;
  }

  .ai-comparison-chart__highlight-{{ ai_gen_id }}::before {
    content: '{{ block.settings.highlight_label }}';
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background-color: {{ block.settings.highlight_label_bg }};
    color: {{ block.settings.highlight_label_color }};
    padding: 4px 12px;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-chart__container-{{ ai_gen_id }} {
      padding: {{ block.settings.container_padding | times: 0.6 }}px;
    }

    .ai-comparison-chart__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-comparison-chart__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.85 }}px;
    }

    .ai-comparison-chart__table-{{ ai_gen_id }} thead th,
    .ai-comparison-chart__table-{{ ai_gen_id }} tbody td {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
      font-size: {{ block.settings.body_font_size | times: 0.9 }}px;
    }

    .ai-comparison-chart__table-{{ ai_gen_id }} thead th {
      font-size: {{ block.settings.header_font_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-comparison-chart-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-comparison-chart__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-comparison-chart__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-comparison-chart__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <div class="ai-comparison-chart__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    <table class="ai-comparison-chart__table-{{ ai_gen_id }}">
      <thead>
        <tr>
          <th></th>
          {% if block.settings.column_1_title != blank %}
            <th {% if block.settings.highlight_column == '1' %}class="ai-comparison-chart__highlight-{{ ai_gen_id }}"{% endif %}>
              {{ block.settings.column_1_title }}
            </th>
          {% endif %}
          {% if block.settings.number_of_columns >= 2 and block.settings.column_2_title != blank %}
            <th {% if block.settings.highlight_column == '2' %}class="ai-comparison-chart__highlight-{{ ai_gen_id }}"{% endif %}>
              {{ block.settings.column_2_title }}
            </th>
          {% endif %}
          {% if block.settings.number_of_columns >= 3 and block.settings.column_3_title != blank %}
            <th {% if block.settings.highlight_column == '3' %}class="ai-comparison-chart__highlight-{{ ai_gen_id }}"{% endif %}>
              {{ block.settings.column_3_title }}
            </th>
          {% endif %}
          {% if block.settings.number_of_columns >= 4 and block.settings.column_4_title != blank %}
            <th {% if block.settings.highlight_column == '4' %}class="ai-comparison-chart__highlight-{{ ai_gen_id }}"{% endif %}>
              {{ block.settings.column_4_title }}
            </th>
          {% endif %}
        </tr>
      </thead>
      <tbody>
        {% for i in (1..10) %}
          {% liquid
            assign feature_key = 'feature_' | append: i
            assign feature_align_key = 'feature_' | append: i | append: '_alignment'
            assign col1_key = 'feature_' | append: i | append: '_col1'
            assign col2_key = 'feature_' | append: i | append: '_col2'
            assign col3_key = 'feature_' | append: i | append: '_col3'
            assign col4_key = 'feature_' | append: i | append: '_col4'

            assign feature_name = block.settings[feature_key]
            assign feature_alignment = block.settings[feature_align_key]
            assign col1_value = block.settings[col1_key]
            assign col2_value = block.settings[col2_key]
            assign col3_value = block.settings[col3_key]
            assign col4_value = block.settings[col4_key]
          %}

          {% if feature_name != blank %}
            <tr>
              <td class="ai-comparison-chart__feature-{{ feature_alignment }}-{{ ai_gen_id }}">{{ feature_name }}</td>
              {% if block.settings.column_1_title != blank %}
                <td {% if block.settings.highlight_column == '1' %}class="ai-comparison-chart__highlight-{{ ai_gen_id }}"{% endif %}>
                  {% if col1_value == 'check' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__checkmark-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                  {% elsif col1_value == 'cross' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__cross-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                  {% else %}
                    {{ col1_value }}
                  {% endif %}
                </td>
              {% endif %}
              {% if block.settings.number_of_columns >= 2 and block.settings.column_2_title != blank %}
                <td {% if block.settings.highlight_column == '2' %}class="ai-comparison-chart__highlight-{{ ai_gen_id }}"{% endif %}>
                  {% if col2_value == 'check' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__checkmark-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                  {% elsif col2_value == 'cross' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__cross-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                  {% else %}
                    {{ col2_value }}
                  {% endif %}
                </td>
              {% endif %}
              {% if block.settings.number_of_columns >= 3 and block.settings.column_3_title != blank %}
                <td {% if block.settings.highlight_column == '3' %}class="ai-comparison-chart__highlight-{{ ai_gen_id }}"{% endif %}>
                  {% if col3_value == 'check' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__checkmark-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                  {% elsif col3_value == 'cross' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__cross-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                  {% else %}
                    {{ col3_value }}
                  {% endif %}
                </td>
              {% endif %}
              {% if block.settings.number_of_columns >= 4 and block.settings.column_4_title != blank %}
                <td {% if block.settings.highlight_column == '4' %}class="ai-comparison-chart__highlight-{{ ai_gen_id }}"{% endif %}>
                  {% if col4_value == 'check' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__checkmark-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                  {% elsif col4_value == 'cross' %}
                    <span class="ai-comparison-chart__icon-{{ ai_gen_id }} ai-comparison-chart__cross-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                  {% else %}
                    {{ col4_value }}
                  {% endif %}
                </td>
              {% endif %}
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

