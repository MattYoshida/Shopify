        "custom_liquid_Ch8apc": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% if product.metafields.custom.related_bundles.value %}\n  <div class=\"bundle-switcher\" id=\"bundle-switcher\">\n    <span class=\"bundle-switcher__label\">Shop the full collection</span>\n    {% for bundle in product.metafields.custom.related_bundles.value %}\n      <a href=\"{{ bundle.url }}\"\n         class=\"bundle-option{% if bundle.handle == product.handle %} active{% endif %}{% unless bundle.available %} disabled{% endunless %}\"\n         data-handle=\"{{ bundle.handle }}\">\n        {{ bundle.metafields.custom.title_product_count }}\n      </a>\n    {% endfor %}\n  </div>\n  <script>\n    (function() {\n      function initBundleSwitcher() {\n        var switcher = document.getElementById('bundle-switcher');\n        if (!switcher) return;\n        switcher.addEventListener('click', function(e) {\n          var link = e.target.closest('.bundle-option');\n          if (!link || link.classList.contains('active') || link.classList.contains('disabled')) return;\n          e.preventDefault();\n          var url = link.getAttribute('href');\n          var mainSection = document.querySelector('[id$=\"__main\"]') || document.querySelector('[id=\"shopify-section-main\"]');\n          if (!mainSection) { window.location.href = url; return; }\n          var sectionId = mainSection.id.replace('shopify-section-', '');\n          mainSection.classList.add('bundle-switching');\n          fetch(url + '?sections=' + encodeURIComponent(sectionId))\n            .then(function(r) { return r.json(); })\n            .then(function(data) {\n              var html = data[sectionId];\n              if (!html) { window.location.href = url; return; }\n              var parser = new DOMParser();\n              var doc = parser.parseFromString(html, 'text/html');\n              var newSection = doc.querySelector('[id$=\"__main\"]') || doc.querySelector('[id=\"shopify-section-main\"]');\n              if (!newSection) { window.location.href = url; return; }\n              mainSection.innerHTML = newSection.innerHTML;\n              history.pushState({}, '', url);\n              document.dispatchEvent(new CustomEvent('shopify:section:load', { detail: { sectionId: sectionId } }));\n              mainSection.classList.remove('bundle-switching');\n            })\n            .catch(function() { window.location.href = url; });\n        });\n      }\n      if (document.readyState === 'loading') {\n        document.addEventListener('DOMContentLoaded', initBundleSwitcher);\n      } else {\n        initBundleSwitcher();\n      }\n    })();\n  </script>\n{% endif %}"
          }
        },
        "custom_liquid_wgiXpb": {
          "type": "custom_liquid",
          "disabled": true,
          "settings": {
            "custom_liquid": "<div class=\"holiday-rush-banner\">\n  <svg class=\"banner-icon\" xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"none\">\n    <path d=\"M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41L12 0Z\"></path>\n  </svg>\n  <span class=\"banner-text\">LIMITED TIME OFFER</span>\n</div>\n\n<style>\n  .holiday-rush-banner {\n    display: flex;\n    align-items: flex-end; /* Aligns content to the very bottom */\n    justify-content: flex-start;\n    padding: 10px 0 0 0; /* 10px Top, 0px Bottom */\n    background-color: #ffffff;\n    border-radius: 4px;\n    width: 100%;\n    line-height: 1; /* Removes invisible space below the text */\n  }\n\n  .banner-icon {\n    color: #4CAF50; \n    margin-right: 8px;\n    width: 18px; \n    height: 18px;\n    margin-bottom: 1px; /* Slight tweak to align visually with text baseline */\n  }\n\n  .banner-text {\n    color: #D32F2F;\n    font-family: sans-serif; \n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 1px;\n    line-height: 0.8; /* Extremely tight line-height to remove font padding */\n  }\n</style>"
          }
        },
        "custom_liquid_VXFAaC": {
          "type": "custom_liquid",
          "disabled": true,
          "settings": {
            "custom_liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Lato:wght@400;700&display=swap');\n\n  .cart-counter-widget {\n    display: flex;\n    align-items: center;\n    justify-content: center; /* Centers the text */\n    padding: 10px;\n    margin-bottom: 15px;\n    background-color: #f4f4f4; /* Light grey background */\n    border-radius: 4px;\n    font-size: 14px;\n    color: #000000; /* Standard black text */\n    font-family: 'Lato', sans-serif; /* Sets font to Lato */\n    width: 100%; /* Spans full width of container */\n  }\n\n  .cart-counter-count {\n    font-weight: 700; /* Bold the number */\n    color: inherit; /* Matches the text color (not red) */\n  }\n</style>\n\n<div class=\"cart-counter-widget\" id=\"cartCounterWidget\" style=\"display:none;\">\n  <span>\n    <span class=\"cart-counter-count\" id=\"cartCounterNumber\">120</span> \n    people have this in their cart right now.\n  </span>\n</div>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function() {\n    // CONFIGURATION\n    var minPeople = 100; // Minimum number of people\n    var maxPeople = 140; // Maximum number of people\n    var updateInterval = 120000; // 2 minutes in milliseconds (120,000ms)\n    \n    var widget = document.getElementById('cartCounterWidget');\n    var countSpan = document.getElementById('cartCounterNumber');\n    \n    // Function to generate random integer between min and max\n    function getRandomInt(min, max) {\n      return Math.floor(Math.random() * (max - min + 1)) + min;\n    }\n\n    // Initialize logic\n    var currentCount = localStorage.getItem('cartCount_simulation');\n    \n    // If no stored count, generate a starting number\n    if (!currentCount) {\n      currentCount = getRandomInt(minPeople, maxPeople);\n    } else {\n      currentCount = parseInt(currentCount);\n    }\n\n    // Display the initial number and show widget\n    countSpan.innerText = currentCount;\n    widget.style.display = \"flex\";\n\n    // Update the count periodically\n    setInterval(function() {\n      // Decide whether to go up or down (50/50 chance)\n      var change = Math.random() < 0.5 ? -1 : 1;\n      var fluctuation = getRandomInt(1, 4); // Change by 1 to 4 people\n      \n      currentCount += (change * fluctuation);\n\n      // Keep within bounds\n      if (currentCount > maxPeople) currentCount = maxPeople - 2;\n      if (currentCount < minPeople) currentCount = minPeople + 2;\n\n      // Update DOM and Storage\n      countSpan.innerText = currentCount;\n      localStorage.setItem('cartCount_simulation', currentCount);\n      \n    }, updateInterval);\n  });\n</script>"
          }
