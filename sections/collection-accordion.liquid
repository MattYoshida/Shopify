{%- liquid
  assign section_heading = section.settings.heading
  assign section_subheading = section.settings.subheading
-%}

<style>
  #shopify-section-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .collection-accordion__heading-wrapper {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: 32px;
  }

  .collection-accordion__subheading {
    display: block;
    font-size: 0.85em;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 8px;
    color: {{ section.settings.text_color }};
  }

  .collection-accordion__title {
    margin: 0;
    color: {{ section.settings.text_color }};
  }

  .collection-accordion__grid {
    display: flex;
    height: calc(100vw / {{ section.blocks.size | default: 4 }} * 1.0);
    max-height: {{ section.settings.max_height }}px;
    overflow: hidden;
    gap: 4px;
  }

  @media screen and (max-width: 767px) {
    .collection-accordion__grid {
      flex-direction: row;
      height: {{ section.settings.mobile_card_height }}px;
      overflow-x: scroll;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 0;
    }
    .collection-accordion__grid::-webkit-scrollbar {
      display: none;
    }
  }

  .collection-accordion__card {
    position: relative;
    flex-grow: 1;
    flex-shrink: 1;
    flex-basis: 0;
    overflow: hidden;
    cursor: pointer;
    transition: flex-grow 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media screen and (min-width: 768px) {
    .collection-accordion__grid:hover .collection-accordion__card {
      flex-grow: 0.8;
    }

    .collection-accordion__grid:hover .collection-accordion__card:hover {
      flex-grow: 1.8;
    }
  }

  @media screen and (max-width: 767px) {
    .collection-accordion__card {
      flex: 0 0 100%;
      height: 100%;
      scroll-snap-align: start;
    }
    .collection-accordion__card-btn {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
  }

  .collection-accordion__image-wrapper {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .collection-accordion__image-wrapper img {
    filter: brightness({{ section.settings.image_opacity | divided_by: 100.0 }});
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    display: block;
  }

  .collection-accordion__card:hover .collection-accordion__image-wrapper img {
    transform: scale(1.05);
  }

  .collection-accordion__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }}) 0%,
      rgba(0, 0, 0, 0.1) 50%,
      rgba(0, 0, 0, 0) 100%
    );
  }

  .collection-accordion__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 28px 24px;
    color: #ffffff;
    transform: translateY(0);
  }

  .collection-accordion__card-subheading {
    display: block;
    font-size: {{ section.settings.subheading_size }}px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 6px;
    opacity: 0.85;
  }

  .collection-accordion__card-title {
    margin: 0 0 16px;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.2;
    color: #ffffff;
  }

  .collection-accordion__card-btn {
    display: inline-block;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease 0.1s, transform 0.3s ease 0.1s;
    pointer-events: none;
  }

  .collection-accordion__card:hover .collection-accordion__card-btn {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  @media screen and (max-width: 767px) {
    .collection-accordion__card-btn {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
  }

  .collection-accordion__btn {
    display: inline-block;
    padding: 10px 24px;
    font-size: 0.8em;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid #ffffff;
    color: #ffffff;
    background: transparent;
    transition: background 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .collection-accordion__btn:hover {
    background: #ffffff;
    color: #000000;
  }

  .collection-accordion__btn--filled {
    background: #ffffff;
    color: #000000;
  }

  .collection-accordion__btn--filled:hover {
    background: transparent;
    color: #ffffff;
  }

  .collection-accordion__dots {
    display: none;
  }

  @media screen and (max-width: 767px) {
    .collection-accordion__dots {
      display: flex;
      justify-content: center;
      gap: 8px;
      padding-top: 14px;
    }

    .collection-accordion__dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #d0d0d0;
      transition: background 0.3s ease;
      cursor: pointer;
      border: none;
      padding: 0;
    }

    .collection-accordion__dot.is-active {
      background: #111111;
    }
  }
</style>

<div class="collection-accordion page-width">
  {%- if section_heading != blank or section_subheading != blank -%}
    <div class="collection-accordion__heading-wrapper">
      {%- if section_subheading != blank -%}
        <span class="collection-accordion__subheading">{{ section_subheading }}</span>
      {%- endif -%}
      {%- if section_heading != blank -%}
        <h2 class="collection-accordion__title h1">{{ section_heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="collection-accordion__grid">
      {%- for block in section.blocks -%}
        {%- assign btn_label = block.settings.button_label -%}
        {%- assign btn_link = block.settings.button_link -%}
        <div class="collection-accordion__card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="collection-accordion__image-wrapper">
              {{- block.settings.image | image_url: width: 1200 | image_tag:
                loading: 'lazy',
                widths: '400, 600, 800, 1000, 1200',
                sizes: '(max-width: 767px) 100vw, 25vw',
                alt: block.settings.image.alt | default: block.settings.heading
              -}}
            </div>
          {%- else -%}
            <div class="collection-accordion__image-wrapper" style="background: #e8e8e8;"></div>
          {%- endif -%}

          <div class="collection-accordion__overlay"></div>

          <div class="collection-accordion__content">
            {%- if block.settings.subheading != blank -%}
              <span class="collection-accordion__card-subheading">{{ block.settings.subheading }}</span>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h3 class="collection-accordion__card-title">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if btn_label != blank -%}
              <div class="collection-accordion__card-btn">
                <a
                  href="{{ btn_link | default: '#' }}"
                  class="collection-accordion__btn{% if block.settings.button_style == 'filled' %} collection-accordion__btn--filled{% endif %}"
                >
                  {{- btn_label -}}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
    <div class="collection-accordion__dots" aria-hidden="true">
      {%- for block in section.blocks -%}
        <button class="collection-accordion__dot{% if forloop.first %} is-active{% endif %}"></button>
      {%- endfor -%}
    </div>
  {%- else -%}
    {%- if request.design_mode -%}
      <div style="padding: 40px; text-align: center; background: #f4f4f4; color: #999;">
        Add collection cards using the blocks panel.
      </div>
    {%- endif -%}
  {%- endif -%}
</div>

<script>
  (function() {
    var section = document.querySelector('#shopify-section-{{ section.id }}');
    if (!section) return;
    var grid = section.querySelector('.collection-accordion__grid');
    var dots = section.querySelectorAll('.collection-accordion__dot');
    if (!grid || !dots.length) return;

    function updateDots() {
      var index = Math.round(grid.scrollLeft / grid.offsetWidth);
      dots.forEach(function(dot, i) {
        dot.classList.toggle('is-active', i === index);
      });
    }

    grid.addEventListener('scroll', updateDots, { passive: true });

    dots.forEach(function(dot, i) {
      dot.addEventListener('click', function() {
        grid.scrollTo({ left: grid.offsetWidth * i, behavior: 'smooth' });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Collection Accordion",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Section heading color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Card heading size",
      "default": 22
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Card subheading size",
      "default": 11
    },
    {
      "type": "range",
      "id": "max_height",
      "min": 400,
      "max": 900,
      "step": 10,
      "unit": "px",
      "label": "Max height cap (desktop)",
      "info": "Height auto-scales to square ratio per card. This caps the max.",
      "default": 560
    },
    {
      "type": "range",
      "id": "mobile_card_height",
      "min": 200,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Card height (mobile)",
      "default": 300
    },
    {
      "type": "range",
      "id": "image_opacity",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image opacity",
      "default": 100
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 55
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Collection card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "placeholder": "e.g. New Collection"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "placeholder": "e.g. Ultrasoft Towels"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "outline", "label": "Outline" },
            { "value": "filled", "label": "Filled" }
          ],
          "default": "outline"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Accordion",
      "blocks": [
        { "type": "card", "settings": { "heading": "Collection One", "button_label": "Shop now" } },
        { "type": "card", "settings": { "heading": "Collection Two", "button_label": "Shop now" } },
        { "type": "card", "settings": { "heading": "Collection Three", "button_label": "Shop now" } },
        { "type": "card", "settings": { "heading": "Collection Four", "button_label": "Shop now" } }
      ]
    }
  ]
}
{% endschema %}
